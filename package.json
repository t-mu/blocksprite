{
	"name": "blocksprite",
	"version": "0.1.0",
	"private": true,
	"description": "A simple sprite editor.",
	"keywords": [
		"Sprite",
		"editor",
		"pixel",
		"art",
		"game",
		"development"
	],
	"homepage": "https://github.com/t-mu/blocksprite#readme",
	"bugs": {
		"url": "https://github.com/t-mu/blocksprite/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/t-mu/blocksprite.git"
	},
	"license": "ISC",
	"author": "Teemu Mäntyharju",
	"type": "module",
	"packageManager": "pnpm@10.33.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.5",
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.59.1",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@types/node": "24.12.2",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"globals": "17.5.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.1",
		"svelte": "5.55.4",
		"svelte-check": "4.4.6",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.0",
		"vite": "8.0.9",
		"vitest": "4.1.5"
	}
}
